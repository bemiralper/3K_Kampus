"use client";

import { useState } from "react";

type TabType = "sinif_seviyeleri" | "alanlar" | "dersler" | "branslar";

type TanimlarResponse = {
  sinif_seviyeleri?: Array<{ id: number; ad: string; kod: string; aktif_mi: boolean }>;
  alanlar?: Array<{ id: number; ad: string; kod: string; aktif_mi: boolean }>;
  dersler?: Array<{ id: number; ad: string; kod: string; aktif_mi: boolean }>;
  branslar?: Array<{ id: number; ad: string; kod: string; aktif_mi: boolean }>;
};

interface EgitimTanimlariClientProps {
  initialData: TanimlarResponse;
}

export default function EgitimTanimlariClient({ initialData }: EgitimTanimlariClientProps) {
  const [activeTab, setActiveTab] = useState<TabType>("sinif_seviyeleri");
  const data = initialData;

  const sinifCount = data.sinif_seviyeleri?.length ?? 0;
  const alanCount = data.alanlar?.length ?? 0;
  const dersCount = data.dersler?.length ?? 0;
  const bransCount = data.branslar?.length ?? 0;

  const getIconColors = (index: number) => {
    const colors = ['blue', 'green', 'purple', 'orange', 'pink', 'teal'];
    return colors[index % colors.length];
  };

  return (
    <div className="section">
      {/* Page Header */}
      <div className="page-header">
        <div className="page-header-left">
          <h2>Eğitim Tanımları</h2>
          <div className="breadcrumb">
            <a href="/dashboard">Ana Sayfa</a>
            <span>/</span>
            <span>Kurum Ayarları</span>
            <span>/</span>
            <span>Eğitim Tanımları</span>
          </div>
        </div>
        <div className="page-header-right">
          <button className="btn-modern btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
              <line x1="12" y1="5" x2="12" y2="19" />
              <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
            Yeni Ekle
          </button>
        </div>
      </div>

      {/* Quick Stats */}
      <div className="quick-stats">
        <div className="quick-stat">
          <div className="quick-stat-icon blue">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
            </svg>
          </div>
          <div className="quick-stat-info">
            <h4>{sinifCount}</h4>
            <span>Sınıf Seviyesi</span>
          </div>
        </div>
        <div className="quick-stat">
          <div className="quick-stat-icon green">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
              <rect x="3" y="3" width="7" height="7" />
              <rect x="14" y="3" width="7" height="7" />
              <rect x="14" y="14" width="7" height="7" />
              <rect x="3" y="14" width="7" height="7" />
            </svg>
          </div>
          <div className="quick-stat-info">
            <h4>{alanCount}</h4>
            <span>Alan</span>
          </div>
        </div>
        <div className="quick-stat">
          <div className="quick-stat-icon purple">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
              <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
            </svg>
          </div>
          <div className="quick-stat-info">
            <h4>{dersCount}</h4>
            <span>Ders</span>
          </div>
        </div>
        <div className="quick-stat">
          <div className="quick-stat-icon orange">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
              <circle cx="9" cy="7" r="4" />
              <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
              <path d="M16 3.13a4 4 0 0 1 0 7.75" />
            </svg>
          </div>
          <div className="quick-stat-info">
            <h4>{bransCount}</h4>
            <span>Branş</span>
          </div>
        </div>
      </div>

      {/* Modern Tabs - Client-side onClick instead of href */}
      <div className="tabs-modern">
        <a 
          className={`tab-modern ${activeTab === "sinif_seviyeleri" ? "active" : ""}`} 
          href="#"
          onClick={(e) => { e.preventDefault(); setActiveTab("sinif_seviyeleri"); }}
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
          </svg>
          Sınıf Seviyeleri
          <span className="tab-count">{sinifCount}</span>
        </a>
        <a 
          className={`tab-modern ${activeTab === "alanlar" ? "active" : ""}`} 
          href="#"
          onClick={(e) => { e.preventDefault(); setActiveTab("alanlar"); }}
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
            <rect x="3" y="3" width="7" height="7" />
            <rect x="14" y="3" width="7" height="7" />
            <rect x="14" y="14" width="7" height="7" />
            <rect x="3" y="14" width="7" height="7" />
          </svg>
          Alanlar
          <span className="tab-count">{alanCount}</span>
        </a>
        <a 
          className={`tab-modern ${activeTab === "dersler" ? "active" : ""}`} 
          href="#"
          onClick={(e) => { e.preventDefault(); setActiveTab("dersler"); }}
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
          </svg>
          Dersler
          <span className="tab-count">{dersCount}</span>
        </a>
        <a 
          className={`tab-modern ${activeTab === "branslar" ? "active" : ""}`} 
          href="#"
          onClick={(e) => { e.preventDefault(); setActiveTab("branslar"); }}
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
            <circle cx="9" cy="7" r="4" />
            <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
            <path d="M16 3.13a4 4 0 0 1 0 7.75" />
          </svg>
          Branşlar
          <span className="tab-count">{bransCount}</span>
        </a>
      </div>

      {/* Sınıf Seviyeleri Tab */}
      {activeTab === "sinif_seviyeleri" && (
        <div className="card-modern">
          <div className="card-modern-header">
            <h3>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
              </svg>
              Sınıf Seviyeleri Listesi
            </h3>
            <div className="card-modern-header-actions">
              <div className="search-modern">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                  <circle cx="11" cy="11" r="8" />
                  <line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
                <input type="text" placeholder="Sınıf ara..." />
              </div>
            </div>
          </div>
          <div className="card-modern-body">
            {(data.sinif_seviyeleri ?? []).length > 0 ? (
              <table className="table-modern">
                <thead>
                  <tr>
                    <th>Sınıf Seviyesi</th>
                    <th>Kod</th>
                    <th>Durum</th>
                    <th style={{ width: '100px' }}>İşlemler</th>
                  </tr>
                </thead>
                <tbody>
                  {(data.sinif_seviyeleri ?? []).map((item, index) => (
                    <tr key={item.id}>
                      <td>
                        <div className="cell-with-icon">
                          <div className={`cell-icon ${getIconColors(index)}`}>
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
                            </svg>
                          </div>
                          <div className="cell-info">
                            <span className="cell-primary">{item.ad}</span>
                            <span className="cell-secondary">Eğitim Seviyesi</span>
                          </div>
                        </div>
                      </td>
                      <td>
                        <span className="badge-modern primary">{item.kod}</span>
                      </td>
                      <td>
                        <span className={`badge-modern ${item.aktif_mi ? "success" : "danger"}`}>
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                            {item.aktif_mi ? (
                              <polyline points="20 6 9 17 4 12" />
                            ) : (
                              <><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></>
                            )}
                          </svg>
                          {item.aktif_mi ? "Aktif" : "Pasif"}
                        </span>
                      </td>
                      <td>
                        <div className="row-actions">
                          <button className="row-action-btn" title="Düzenle">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                            </svg>
                          </button>
                          <button className="row-action-btn danger" title="Sil">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                              <polyline points="3 6 5 6 21 6" />
                              <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                            </svg>
                          </button>
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            ) : (
              <div className="empty-state">
                <div className="empty-state-icon">📚</div>
                <h4>Henüz sınıf seviyesi eklenmemiş</h4>
                <p>İlk sınıf seviyenizi ekleyerek başlayın</p>
                <button className="btn-modern btn-primary">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                    <line x1="12" y1="5" x2="12" y2="19" />
                    <line x1="5" y1="12" x2="19" y2="12" />
                  </svg>
                  Sınıf Seviyesi Ekle
                </button>
              </div>
            )}
          </div>
        </div>
      )}

      {/* Alanlar Tab */}
      {activeTab === "alanlar" && (
        <div className="card-modern">
          <div className="card-modern-header">
            <h3>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                <rect x="3" y="3" width="7" height="7" />
                <rect x="14" y="3" width="7" height="7" />
                <rect x="14" y="14" width="7" height="7" />
                <rect x="3" y="14" width="7" height="7" />
              </svg>
              Alanlar Listesi
            </h3>
            <div className="card-modern-header-actions">
              <div className="search-modern">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                  <circle cx="11" cy="11" r="8" />
                  <line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
                <input type="text" placeholder="Alan ara..." />
              </div>
            </div>
          </div>
          <div className="card-modern-body">
            {(data.alanlar ?? []).length > 0 ? (
              <table className="table-modern">
                <thead>
                  <tr>
                    <th>Alan Adı</th>
                    <th>Kod</th>
                    <th>Durum</th>
                    <th style={{ width: '100px' }}>İşlemler</th>
                  </tr>
                </thead>
                <tbody>
                  {(data.alanlar ?? []).map((item, index) => (
                    <tr key={item.id}>
                      <td>
                        <div className="cell-with-icon">
                          <div className={`cell-icon ${getIconColors(index)}`}>
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                              <rect x="3" y="3" width="7" height="7" />
                              <rect x="14" y="3" width="7" height="7" />
                              <rect x="14" y="14" width="7" height="7" />
                              <rect x="3" y="14" width="7" height="7" />
                            </svg>
                          </div>
                          <div className="cell-info">
                            <span className="cell-primary">{item.ad}</span>
                            <span className="cell-secondary">Eğitim Alanı</span>
                          </div>
                        </div>
                      </td>
                      <td>
                        <span className="badge-modern primary">{item.kod}</span>
                      </td>
                      <td>
                        <span className={`badge-modern ${item.aktif_mi ? "success" : "danger"}`}>
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                            {item.aktif_mi ? (
                              <polyline points="20 6 9 17 4 12" />
                            ) : (
                              <><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></>
                            )}
                          </svg>
                          {item.aktif_mi ? "Aktif" : "Pasif"}
                        </span>
                      </td>
                      <td>
                        <div className="row-actions">
                          <button className="row-action-btn" title="Düzenle">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                            </svg>
                          </button>
                          <button className="row-action-btn danger" title="Sil">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                              <polyline points="3 6 5 6 21 6" />
                              <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                            </svg>
                          </button>
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            ) : (
              <div className="empty-state">
                <div className="empty-state-icon">📦</div>
                <h4>Henüz alan eklenmemiş</h4>
                <p>İlk alanınızı ekleyerek başlayın</p>
                <button className="btn-modern btn-primary">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                    <line x1="12" y1="5" x2="12" y2="19" />
                    <line x1="5" y1="12" x2="19" y2="12" />
                  </svg>
                  Alan Ekle
                </button>
              </div>
            )}
          </div>
        </div>
      )}

      {/* Dersler Tab */}
      {activeTab === "dersler" && (
        <div className="card-modern">
          <div className="card-modern-header">
            <h3>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
              </svg>
              Dersler Listesi
            </h3>
            <div className="card-modern-header-actions">
              <div className="search-modern">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                  <circle cx="11" cy="11" r="8" />
                  <line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
                <input type="text" placeholder="Ders ara..." />
              </div>
            </div>
          </div>
          <div className="card-modern-body">
            {(data.dersler ?? []).length > 0 ? (
              <table className="table-modern">
                <thead>
                  <tr>
                    <th>Ders Adı</th>
                    <th>Kod</th>
                    <th>Durum</th>
                    <th style={{ width: '100px' }}>İşlemler</th>
                  </tr>
                </thead>
                <tbody>
                  {(data.dersler ?? []).map((item, index) => (
                    <tr key={item.id}>
                      <td>
                        <div className="cell-with-icon">
                          <div className={`cell-icon ${getIconColors(index)}`}>
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
                              <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
                            </svg>
                          </div>
                          <div className="cell-info">
                            <span className="cell-primary">{item.ad}</span>
                            <span className="cell-secondary">Ders</span>
                          </div>
                        </div>
                      </td>
                      <td>
                        <span className="badge-modern primary">{item.kod}</span>
                      </td>
                      <td>
                        <span className={`badge-modern ${item.aktif_mi ? "success" : "danger"}`}>
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                            {item.aktif_mi ? (
                              <polyline points="20 6 9 17 4 12" />
                            ) : (
                              <><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></>
                            )}
                          </svg>
                          {item.aktif_mi ? "Aktif" : "Pasif"}
                        </span>
                      </td>
                      <td>
                        <div className="row-actions">
                          <button className="row-action-btn" title="Düzenle">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                            </svg>
                          </button>
                          <button className="row-action-btn danger" title="Sil">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                              <polyline points="3 6 5 6 21 6" />
                              <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                            </svg>
                          </button>
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            ) : (
              <div className="empty-state">
                <div className="empty-state-icon">📖</div>
                <h4>Henüz ders eklenmemiş</h4>
                <p>İlk dersinizi ekleyerek başlayın</p>
                <button className="btn-modern btn-primary">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                    <line x1="12" y1="5" x2="12" y2="19" />
                    <line x1="5" y1="12" x2="19" y2="12" />
                  </svg>
                  Ders Ekle
                </button>
              </div>
            )}
          </div>
        </div>
      )}

      {/* Branşlar Tab */}
      {activeTab === "branslar" && (
        <div className="card-modern">
          <div className="card-modern-header">
            <h3>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                <circle cx="9" cy="7" r="4" />
                <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                <path d="M16 3.13a4 4 0 0 1 0 7.75" />
              </svg>
              Branşlar Listesi
            </h3>
            <div className="card-modern-header-actions">
              <div className="search-modern">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                  <circle cx="11" cy="11" r="8" />
                  <line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
                <input type="text" placeholder="Branş ara..." />
              </div>
            </div>
          </div>
          <div className="card-modern-body">
            {(data.branslar ?? []).length > 0 ? (
              <table className="table-modern">
                <thead>
                  <tr>
                    <th>Branş Adı</th>
                    <th>Kod</th>
                    <th>Durum</th>
                    <th style={{ width: '100px' }}>İşlemler</th>
                  </tr>
                </thead>
                <tbody>
                  {(data.branslar ?? []).map((item, index) => (
                    <tr key={item.id}>
                      <td>
                        <div className="cell-with-icon">
                          <div className={`cell-icon ${getIconColors(index)}`}>
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                              <circle cx="9" cy="7" r="4" />
                              <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                              <path d="M16 3.13a4 4 0 0 1 0 7.75" />
