# Production Docker — kopyalayın: cp .env.production.docker.example .env.production.docker
# Canlı systemd/nginx kurulumu bu dosyadan etkilenmez.

DJANGO_ENV=production
ENVIRONMENT_LABEL=Canlı Docker

# Önerilen: mevcut sunucu PostgreSQL (Docker dışında)
# Linux: host.docker.internal → docker-compose.prod.yml extra_hosts ile gelir
DB_NAME=lms_db
DB_USER=
DB_PASSWORD=
DB_HOST=host.docker.internal
DB_PORT=5432
DB_SSLMODE=disable

SECRET_KEY=
ALLOWED_HOSTS=app.3kkampus.com,localhost
FRONTEND_URL=https://app.3kkampus.com
CSRF_TRUSTED_ORIGINS_EXTRA=https://app.3kkampus.com
SECURE_SSL_REDIRECT=false

NEXT_PUBLIC_BACKEND_URL=http://backend:8000

# production.py zorunlu kılar
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WABA_ID=
WHATSAPP_VERIFY_TOKEN=

# Opsiyonel
# CELERY_BROKER_URL=redis://redis:6379/0
# BACKUP_LOCAL_ROOT=/var/lib/3k/backups

# bundled-db profile kullanıyorsanız DB_HOST=db yapın
