# Canlı ortam — sunucuda /etc/lms/env veya systemd EnvironmentFile olarak kullanın
DJANGO_ENV=production
SECRET_KEY=
ALLOWED_HOSTS=app.sizinkurum.com,api.sizinkurum.com

DB_NAME=lms_db
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
# Aynı sunucu PG (SSL yok): disable | managed DB: require
DB_SSLMODE=disable

FRONTEND_URL=https://app.sizinkurum.com
CSRF_TRUSTED_ORIGINS_EXTRA=https://app.sizinkurum.com

# WhatsApp (production.py zorunlu kılar)
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WABA_ID=
WHATSAPP_VERIFY_TOKEN=

# Deploy script servis adları (systemd unit isimleri)
# LMS_BACKEND_SERVICE=lms-backend
# LMS_FRONTEND_SERVICE=lms-frontend
# LMS_APP_ROOT=/var/www/lms
