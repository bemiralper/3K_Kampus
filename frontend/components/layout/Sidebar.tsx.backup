"use client";

import Image from "next/image";
import Link from "next/link";
import { useEffect, useMemo, useState } from "react";
import { usePathname } from "next/navigation";

const navSections = [
  {
    id: "dashboard",
    title: "Dashboard",
    items: [
      {
        label: "Genel Bakış",
        href: "/dashboard",
        icon: (
          <svg viewBox="0 0 24 24" className="nav-icon" aria-hidden="true">
            <path
              d="M4 13.5V6.8c0-1.2.8-2.3 2-2.6l4-1.3c1.3-.4 2.7.6 2.7 1.9v8.7a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1Z"
              fill="currentColor"
              opacity="0.35"
            />
            <path
              d="M13 13.5V6.8c0-1.2.8-2.3 2-2.6l4-1.3c1.3-.4 2.7.6 2.7 1.9v13.4a1 1 0 0 1-1 1h-7.7a1 1 0 0 1-1-1v-2.7"
              fill="currentColor"
            />
          </svg>
        ),
      },
    ],
  },
  {
    id: "kurum",
    title: "KURUM Ayarları",
    items: [
      {
        label: "Kurum Yönetimi",
        href: "/kurum-yonetimi/kurumlar",
        icon: (
          <svg viewBox="0 0 24 24" className="nav-icon" aria-hidden="true">
            <path d="M4 10.5 12 4l8 6.5V20a1 1 0 0 1-1 1h-4v-6H9v6H5a1 1 0 0 1-1-1v-9.5Z" fill="currentColor" />
          </svg>
        ),
      },
      {
        label: "Eğitim Tanımları",
        href: "/egitim-tanimlari",
        icon: (
          <svg viewBox="0 0 24 24" className="nav-icon" aria-hidden="true">
            <path d="M5 6.5h14M5 12h14M5 17.5h9" stroke="currentColor" strokeWidth="2" strokeLinecap="round" />
          </svg>
        ),
      },
      {
        label: "Eğitim Paketleri",
        href: "/egitim-paketleri",
        icon: (
          <svg viewBox="0 0 24 24" className="nav-icon" aria-hidden="true">
            <path d="M5 8.5 12 4l7 4.5v7L12 20l-7-4.5v-7Z" stroke="currentColor" strokeWidth="2" fill="none" />
            <path d="M12 9.5v10" stroke="currentColor" strokeWidth="2" strokeLinecap="round" />
          </svg>
        ),
      },
    ],
  },
  {
    id: "ogrenci",
    title: "ÖĞRENCİ Yönetimi",
    items: [
      {
        label: "Öğrenci Listesi",
        href: "/ogrenciler",
        icon: (
          <svg viewBox="0 0 24 24" className="nav-icon" aria-hidden="true">
            <circle cx="8" cy="9" r="3" fill="currentColor" />
            <circle cx="16" cy="8" r="2.4" fill="currentColor" opacity="0.55" />
            <path d="M4.5 18c.6-2.5 2.6-4 5.5-4s4.9 1.5 5.5 4" stroke="currentColor" strokeWidth="2" strokeLinecap="round" fill="none" />
            <path d="M13.5 18c.3-1.6 1.5-2.6 3.3-2.6 1 0 2 .3 2.7 1" stroke="currentColor" strokeWidth="2" strokeLinecap="round" fill="none" opacity="0.55" />
          </svg>
        ),
      },
    ],
  },
];

export default function Sidebar() {
  const pathname = usePathname();
  const defaultOpen = useMemo(() => {
    const match = navSections.find((section) =>
      section.items.some((item) => pathname?.startsWith(item.href))
    );
    return match?.id ?? navSections[0]?.id ?? "dashboard";
  }, [pathname]);
  const [openSection, setOpenSection] = useState<string>(defaultOpen);

  useEffect(() => {
    setOpenSection(defaultOpen);
  }, [defaultOpen]);

  return (
    <aside className="app-sidebar" id="appSidebar">
      <div className="sidebar-brand">
        <Link href="/" className="brand-link">
          <Image src="/img/3k-logo.png" alt="3K Kampüs" width={40} height={40} />
          <span>3K Kampüs LMS</span>
        </Link>
      </div>

      <nav className="sidebar-nav">
        {navSections.map((section) => (
          <div key={section.id} className={`nav-section${openSection === section.id ? " open" : ""}`}>
            <button
              type="button"
              className="nav-section-toggle"
              onClick={() => setOpenSection((prev) => (prev === section.id ? prev : section.id))}
            >
              <span className="nav-section-title">{section.title}</span>
              <span className="nav-section-icon" aria-hidden="true">
                ▾
              </span>
            </button>
            <div className="nav-items" aria-hidden={openSection !== section.id}>
              {section.items.map((item) => (
                <Link
                  key={item.href}
                  href={item.href}
                  className={`nav-link${pathname === item.href ? " active" : ""}`}
                >
                  {item.icon}
                  <span className="nav-label">{item.label}</span>
                </Link>
              ))}
            </div>
          </div>
        ))}
      </nav>
    </aside>
  );
}
