# Local Docker development — kopyalayın: cp .env.docker.example .env.docker
# Native geliştirme (venv + Homebrew PG) bu dosyadan etkilenmez.

DJANGO_ENV=development
ENVIRONMENT_LABEL=Docker Dev

# PostgreSQL (docker-compose.dev.yml içindeki db servisi)
DB_NAME=lms_db
DB_USER=lms
DB_PASSWORD=lms
DB_HOST=db
DB_PORT=5432

SECRET_KEY=docker-dev-insecure-change-me
ALLOWED_HOSTS=localhost,127.0.0.1,backend,0.0.0.0

FRONTEND_URL=http://localhost:3000

# Next.js server-side proxy → backend container hostname
NEXT_PUBLIC_BACKEND_URL=http://backend:8000

# WhatsApp — development'ta boş kalabilir
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WABA_ID=
WHATSAPP_VERIFY_TOKEN=

# Opsiyonel Celery (profile: workers)
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/0
